# App
DEBUG=True
APP_NAME=SIGQ

# Database
DATABASE_URL=sqlite:///./sigq.db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=sigq-evidencias
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Sienge API
SIENGE_BASE_URL=https://api.sienge.com.br/halsten/public/api/v1
SIENGE_USERNAME=your-username
SIENGE_PASSWORD=your-password

# Prevision API
PREVISION_API_URL=https://api.prevision.com.br
PREVISION_TOKEN=your-token

# Entra ID (Microsoft)
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
