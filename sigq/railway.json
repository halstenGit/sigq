{
  "$schema": "https://raw.githubusercontent.com/railwayapp/railway/main/packages/cli/src/schemas/railway.json",
  "services": {
    "postgres": {
      "image": "postgres:16-alpine",
      "environment": {
        "POSTGRES_USER": "sigq",
        "POSTGRES_PASSWORD": "$POSTGRES_PASSWORD",
        "POSTGRES_DB": "sigq"
      },
      "volumes": {
        "postgres_data": "/var/lib/postgresql/data"
      }
    },
    "backend": {
      "build": {
        "context": ".",
        "dockerfile": "backend/Dockerfile"
      },
      "environment": {
        "DATABASE_URL": "postgresql://sigq:$POSTGRES_PASSWORD@postgres:5432/sigq",
        "PYTHONUNBUFFERED": "1"
      },
      "ports": ["8000"],
      "depends_on": ["postgres"]
    },
    "frontend": {
      "build": {
        "context": ".",
        "dockerfile": "frontend/Dockerfile"
      },
      "ports": ["3000"],
      "environment": {
        "VITE_API_URL": "https://api.$RAILWAY_DOMAIN"
      }
    }
  }
}
